# Supabase (Auth + Database + Storage)
# מקור: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Supabase service-role key (server-only, bypasses RLS) — Settings → API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# כתובת האתר — משמשת ל-magic links ו-email callbacks
# בפיתוח: http://localhost:3000  |  בפרודקשן: https://gavish-portal.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — שליחת מייל הרשמה לאחראית הרישום (טופס /join)
# מקור: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
# שולח ביניים: onboarding@resend.dev. להחליף לשולח גביש מאומת אחרי אימות דומיין ב-Resend
RESEND_FROM=קהילת גביש <onboarding@resend.dev>
